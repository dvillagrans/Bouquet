flowchart TD
    %% Palette & Styles
    classDef oltp   fill:#F0FDF4,stroke:#16A34A,stroke-width:1.5px,color:#166534
    classDef silver fill:#F8FAFC,stroke:#94A3B8,stroke-width:1.5px,color:#475569
    classDef gold   fill:#FEFCE8,stroke:#CA8A04,stroke-width:1.5px,color:#854D0E
    classDef job    fill:#FFFFFF,stroke:#000000,stroke-width:2px,color:#000000

    subgraph OLTP2["Tablas Operacionales (Bronze)"]
        OI2["OrderItem<br/>─────────────<br/>id · orderId · menuItemId<br/>quantity · status<br/>totalCents · createdAt"]
        RMI2["RestaurantMenuItem<br/>─────────────<br/>id · restaurantId<br/>categoryId · stationId · name"]
        RC2["RestaurantCategory<br/>─────────────<br/>id · name"]
        ST2["Station<br/>─────────────<br/>id · restaurantId<br/>name · color"]
        RO2["RestaurantOrder<br/>─────────────<br/>id · restaurantId<br/>createdAt"]
    end

    subgraph SILVER2["Capa de Enriquecimiento (Silver)"]
        S3["silver_order_items_enriched<br/>─────────────<br/>orderItemId · menuItemId<br/>itemNameSnapshot · categoryName<br/>stationName · restaurantId<br/>totalCents · quantity · status<br/>createdAt (hora incluida)"]
    end

    subgraph GOLD2["Capa de Negocio (Gold)"]
        G2["analytic_item_velocity<br/>─────────────<br/>menuItemId · itemName<br/>categoryName · stationName<br/>restaurantId<br/>unitsSoldLast7d · unitsSoldLast30d<br/>revenueCentsLast30d<br/>avgUnitsPerHour · peakHour<br/>cancellationCount · computedAt"]
    end

    OI2  -->|"id · menuItemId · quantity<br/>status · totalCents · createdAt"| S3
    RMI2 -->|"id → menuItemId<br/>name → itemNameSnapshot<br/>categoryId · stationId · restaurantId"| S3
    RC2  -->|"id → categoryId<br/>name → categoryName"| S3
    ST2  -->|"id → stationId<br/>name → stationName"| S3
    RO2  -->|"id → orderId<br/>restaurantId · createdAt"| S3

    S3 -->|"menuItemId · itemNameSnapshot<br/>categoryName · stationName<br/>restaurantId · quantity · status<br/>totalCents · createdAt"| AGG2

    AGG2["Job 2 — Item Velocity<br/>FILTER status != CANCELLED<br/>GROUP BY menuItemId · restaurantId<br/>SUM quantity (7d y 30d)<br/>SUM totalCents<br/>peakHour = HOUR with MAX(SUM quantity)<br/>COUNT cancellations"]

    AGG2 --> G2

    class OI2,RMI2,RC2,ST2,RO2 oltp
    class S3 silver
    class G2 gold
    class AGG2 job
