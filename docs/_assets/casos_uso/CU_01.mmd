sequenceDiagram
    autonumber
    
    %% Bouquet Premium Theme
    accTitle: CU-01: Comensal Escanea QR e Ingresa a Mesa Virtual
    accDescr: Flujo de inicialización, activación y acceso compartido a mesa virtual.

    actor M as Mesero
    actor A as Anfitrión
    actor C as Comensal
    participant S as Sistema (Bouquet API)
    participant DB as Base de Datos (PostgreSQL)

    rect rgb(235, 243, 250)
        Note over M,DB: Fase 1: Inicialización (Mesero)
        M->>S: Selecciona mesas físicas
        S->>DB: INSERT MesaVirtual (PENDIENTE)
        S->>DB: UPDATE MesaFisica (status=DISPONIBLE)
        S->>S: Genera JWT (TTL 30 min, one-time)
        S-->>M: Entrega QR con JWT embebido
    end

    rect rgb(235, 243, 250)
        Note over A,DB: Fase 2: Activación de Mesa (Anfitrión)
        A->>S: Escanea QR (GET /api/mesa/:token)
        S->>DB: SELECT status FROM MesaVirtual
        DB-->>S: status: PENDIENTE
        S->>S: Valida Firma JWT + Expiración
        S->>A: Solicita Credenciales de Mesa
        A->>S: POST /activar { guestName, password }
        Note right of S: Cifrado bcrypt de la contraseña
        S->>DB: UPDATE MesaVirtual (status=OCUPADA, pass_hash)
        S->>DB: UPDATE MesaFisica (status=OCUPADA)
        S->>DB: INSERT SesionComensal (isHost=true)
        DB-->>S: Transacción Completada
        S-->>A: Retorna joinCode y Sesión Activa
    end

    rect rgb(235, 243, 250)
        Note over C,DB: Fase 3: Incorporación de Comensales
        C->>S: POST /join { joinCode, guestName }
        S->>DB: SELECT id FROM MesaVirtual
        DB-->>S: Mesa encontrada (OCUPADA)
        S->>DB: INSERT SesionComensal (isHost=false)
        DB-->>S: Sesión Creada
        S-->>C: Acceso al Menú Compartido
    end

    rect rgb(248, 215, 218)
        Note over A,S: Flujos Alternativos y Errores
        A--xS: Token expirado o reutilizado
        S-->>A: HTTP 401 — Código inválido
        A--xS: Mesa ya ocupada o cerrada
        S-->>A: HTTP 409 — Conflicto de estado
    end