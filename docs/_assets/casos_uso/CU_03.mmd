sequenceDiagram
    autonumber
    
    %% Color Palette
    actor K as Chef (Cocina)
    participant S as Sistema (Bouquet API)
    participant DB as Base de Datos (PostgreSQL)
    participant C as Comensal (Notificación)

    rect rgb(235, 243, 250)
        Note over K,S: Fase 1: Recepción de Órdenes
        S->>K: Notificación Realtime (Evento: nueva_orden)
        K->>S: GET /api/orders?status=PENDING
        S->>DB: SELECT orders WHERE restaurantId = ? AND status = PENDING
        DB-->>S: Lista de órdenes pendientes
        S-->>K: Despliegue en Tablero KDS (Kanban)
    end

    rect rgb(214, 239, 216)
        Note over K,DB: Fase 2: Gestión de Preparación
        K->>S: PATCH /api/orders/:id { status: IN_PROGRESS }
        S->>DB: UPDATE Order SET status = IN_PROGRESS
        K->>S: PATCH /api/orders/:id { status: READY }
        S->>DB: UPDATE Order SET status = READY
    end

    rect rgb(255, 240, 214)
        Note over S,C: Fase 3: Notificación de Entrega
        S->>S: Emite evento 'orden_lista' (Realtime)
        S-->>C: Notificación Push / Update UI: "Pedido en Camino"
        K->>S: PATCH /api/orders/:id { status: DELIVERED }
        S->>DB: UPDATE Order SET status = DELIVERED, deliveredAt = NOW()
        S-->>C: Estado Final: Platillo Entregado
    end

    rect rgb(253, 220, 220)
        Note over K,S: Validaciones y SLA
        S->>S: Monitorización de SLA (SLA > 60s sin atender)
        S-->>K: Alerta Visual: Orden con retraso detectado
    end
