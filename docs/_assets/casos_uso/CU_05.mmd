sequenceDiagram
    autonumber
    
    %% Color Palette
    actor G as Gerente / Administrador
    participant S as Sistema (Bouquet Dashboard)
    participant B as Backend (Analytics Engine)
    participant DB as Spark (Gold Tables)

    rect rgb(235, 243, 250)
        Note over G,S: Fase 1: Autenticación y Perfilamiento
        G->>S: Accede a /admin/dashboard
        S->>S: Valida Sesión y Rol (GERENTE | ADMIN)
        S->>S: Identifica nivel organizacional (Sucursal | Zona | Cadena)
    end

    rect rgb(214, 239, 216)
        Note over S,DB: Fase 2: Consulta de Métricas Gold
        S->>B: GET /api/analytics/metrics { orgId, filters }
        B->>B: Aplica filtros RLS según jerarquía
        B->>DB: Query Consumption + Velocity + Service_Time (Gold Layer)
        DB-->>B: Datos agregados y estimaciones exploratorias
        B-->>S: Payload JSON con métricas calculadas
    end

    rect rgb(255, 240, 214)
        Note over G,S: Fase 3: Visualización de Negocio
        S->>S: Renderiza Gráficas Recharts (Consumo, Tiempos, Top Productos)
        S-->>G: Dashboard interactivo en tiempo real
        G->>S: Exportar reporte ejecutivo
        S-->>G: Descarga CSV / PDF
    end

    rect rgb(253, 220, 220)
        Note over G,S: Restricciones de Acceso
        G--xS: Intento de acceso a nivel superior (Zona -> Cadena)
        S-->>G: Error 403 — Privilegios insuficientes (RLS Protection)
    end
