sequenceDiagram
    autonumber
    
    %% Color Palette
    actor G as Gerente
    participant S as Sistema (Bouquet API)
    participant DB as Base de Datos (PostgreSQL)

    rect rgb(235, 243, 250)
        Note over G,DB: Fase 1: Aplicación de Ajuste Autorizado
        G->>S: Selecciona Item o Cuenta -> Aplicar Ajuste
        S->>DB: INSERT AppliedDiscount { type: PERCENT, value: 50, reason: "Cortesía" }
        S->>DB: UPDATE Account (Recalcular Total Interno)
        S-->>G: Ajuste aplicado (Snapshot registrado en auditoría)
    end

    rect rgb(214, 239, 216)
        Note over G,DB: Fase 2: Registro de Motivo y Auditoría
        G->>S: POST /api/adjustments { accountId, reason: "Error de cocina" }
        S->>DB: INSERT AuditLog { action: "MANUAL_ADJUSTMENT", userId, reason }
        DB-->>S: Registro Guardado
        S-->>G: Acción documentada para trazabilidad analítica
    end

    rect rgb(253, 220, 220)
        Note over G,S: Validaciones de Seguridad
        G--xS: Intento de ajuste sin motivo obligatorio
        S-->>G: Error 422 — Justificación requerida para auditoría
    end
