---
config:
  layout: elk
---
erDiagram

    Currency {
        string code PK "MXN | USD | EUR"
        string name
        string symbol
        boolean isActive
        timestamp createdAt
    }

    TaxGroup {
        string id PK
        string name "IVA 16 | IEPS 8 | Exento"
        int rateBps "1600 = 16 percent"
        boolean isActive
        timestamp createdAt
    }

    Permission {
        string id PK
        string code UK "CREATE_ORDER | VIEW_SETTLEMENTS | MANAGE_ADJUSTMENTS"
        string description
        string scope "ENUM RESTAURANT|CHAIN|PLATFORM"
        timestamp createdAt
    }

    Role {
        string id PK
        string chainId FK "nullable"
        string name
        string scope "ENUM RESTAURANT|CHAIN|PLATFORM"
        string description "nullable"
        boolean isBase "true = seed"
        boolean isActive
        timestamp createdAt
        timestamp updatedAt
    }

    RolePermission {
        string roleId FK
        string permissionId FK
        timestamp assignedAt
    }

    AppUser {
        string id PK
        string email UK
        string passwordHash
        string firstName
        string lastName
        string secondLastName "nullable"
        string phone "nullable"
        boolean isActive
        timestamp createdAt
        timestamp updatedAt
    }

    UserRole {
        string id PK
        string userId FK
        string roleId FK
        string contextType "ENUM PLATFORM|CHAIN|ZONE|RESTAURANT"
        string chainId FK "nullable"
        string zoneId FK "nullable"
        string restaurantId FK "nullable"
        timestamp assignedAt
    }

    Chain {
        string id PK
        string createdBy FK
        string currency FK
        string name
        string logoUrl "nullable"
        int defaultTaxBps "1600"
        string defaultTipsBps "array bps"
        boolean isArchived
        timestamp createdAt
        timestamp updatedAt
    }

    Zone {
        string id PK
        string chainId FK
        string name
        boolean isArchived
        timestamp createdAt
        timestamp updatedAt
    }

    Restaurant {
        string id PK
        string chainId FK
        string zoneId FK "nullable"
        string currency FK
        string name
        string logoUrl "nullable"
        string welcomeMessage "nullable"
        string address "nullable"
        int taxBps "nullable"
        string suggestedTipsBps "array bps"
        boolean allowMobileOrdering
        boolean allowWaiterJoinTables
        boolean isArchived
        timestamp createdAt
        timestamp updatedAt
    }

    AuditLog {
        string id PK
        string actorUserId FK
        string chainId "nullable"
        string restaurantId "nullable"
        string action "ENUM CREATE|UPDATE|DELETE|LOGIN|OPEN_SESSION|CLOSE_SESSION|APPLY_ADJUSTMENT|REGISTER_CONTRIBUTION|RUN_ANALYTICS_JOB"
        string entityType
        string entityId
        jsonb before
        jsonb after
        jsonb metadata "nullable"
        string ipAddress "nullable"
        string userAgent "nullable"
        string requestId "nullable"
        timestamp createdAt
    }

    Station {
        string id PK
        string restaurantId FK
        string name "COCINA | BARRA"
        string color "nullable"
        boolean isActive
        timestamp createdAt
        timestamp updatedAt
    }

    MenuTemplate {
        string id PK
        string chainId FK
        string name
        boolean isDefault
        timestamp createdAt
        timestamp updatedAt
    }

    TemplateCategory {
        string id PK
        string templateId FK
        string name
        int order
        timestamp createdAt
        timestamp updatedAt
    }

    TemplateItem {
        string id PK
        string categoryId FK
        string name
        string description "nullable"
        int basePriceCents
        string imageUrl "nullable"
        boolean isPopular
        boolean isArchived
        timestamp createdAt
        timestamp updatedAt
    }

    TemplateItemVariant {
        string id PK
        string templateItemId FK
        string name
        int priceCents
        boolean isAvailable
        int order
        timestamp createdAt
        timestamp updatedAt
    }

    RestaurantCategory {
        string id PK
        string restaurantId FK
        string taxGroupId FK "nullable"
        string name
        int order
        boolean isArchived
        timestamp createdAt
        timestamp updatedAt
    }

    RestaurantMenuItem {
        string id PK
        string restaurantId FK
        string categoryId FK
        string stationId FK "nullable"
        string taxGroupId FK "nullable"
        string templateItemId FK "nullable"
        string name
        string description "nullable"
        int priceCents
        string imageUrl "nullable"
        boolean isPopular
        boolean isSoldOut
        boolean trackStock
        int stockQuantity "nullable"
        int lowStockThreshold "nullable"
        timestamp archivedAt "nullable"
        timestamp createdAt
        timestamp updatedAt
    }

    RestaurantMenuItemVariant {
        string id PK
        string menuItemId FK
        string templateVariantId FK "nullable"
        string name
        int priceCents
        boolean isAvailable
        int order
        timestamp createdAt
        timestamp updatedAt
    }

    ModifierGroup {
        string id PK
        string restaurantId FK
        string name
        boolean isRequired
        int minSelect
        int maxSelect
        timestamp createdAt
        timestamp updatedAt
    }

    ModifierOption {
        string id PK
        string groupId FK
        string name
        int priceAdjustmentCents
        boolean isAvailable
        int order
        timestamp createdAt
        timestamp updatedAt
    }

    MenuItemModifierGroup {
        string menuItemId FK
        string modifierGroupId FK
    }

    DiningTable {
        string id PK
        string restaurantId FK
        int number
        int capacity
        int qrVersion
        string status "ENUM LIBRE|OCUPADA|NO_DISPONIBLE"
        float posX
        float posY
        string shape
        timestamp createdAt
        timestamp updatedAt
    }

    DiningSession {
        string id PK
        string restaurantId FK
        string openedByUserId FK
        string closedByUserId FK "nullable"
        string status "ENUM PENDIENTE_ACTIVACION|ACTIVA|EN_CONSUMO|POR_LIQUIDAR|LIQUIDADA|CERRADA|CANCELADA"
        string joinCode UK
        string accessCodeHash
        int pax
        timestamp openedAt
        timestamp closedAt "nullable"
        timestamp updatedAt
    }

    DiningSessionTable {
        string id PK
        string diningSessionId FK
        string tableId FK
        timestamp joinedAt
        timestamp leftAt "nullable"
    }

    Guest {
        string id PK
        string diningSessionId FK
        string name "nullable"
        int seatNumber "nullable"
        boolean isHost
        boolean isActive
        timestamp joinedAt
        timestamp leftAt "nullable"
        timestamp createdAt
    }

    RestaurantOrder {
        string id PK
        string restaurantId FK
        string diningSessionId FK
        string createdByUserId FK "nullable"
        string source "ENUM WAITER|QR|POS"
        string status "ENUM ABIERTA|ENVIADA|COMPLETADA|CANCELADA"
        timestamp createdAt
        timestamp updatedAt
        timestamp closedAt "nullable"
        timestamp cancelledAt "nullable"
    }

    OrderItem {
        string id PK
        string orderId FK
        string menuItemId FK "nullable"
        string variantId FK "nullable"
        string guestId FK "nullable"
        string stationId FK "nullable"
        string status "ENUM PENDIENTE|EN_PREPARACION|LISTA|ENTREGADA|CANCELADA"
        int quantity
        string notes "nullable"
        string itemNameSnapshot
        string variantNameSnapshot "nullable"
        string stationNameSnapshot "nullable"
        int taxRateBpsSnapshot
        int unitPriceCents
        int subtotalCents
        int taxAmountCents
        int totalCents
        timestamp createdAt
        timestamp updatedAt
    }

    OrderItemModifier {
        string id PK
        string orderItemId FK
        string modifierOptionId FK "nullable"
        string nameSnapshot
        int quantity
        int priceAdjustmentCents
        timestamp createdAt
    }

    OrderItemStatusEvent {
        string id PK
        string orderItemId FK
        string changedByUserId FK "nullable"
        timestamp createdAt
    }

    Settlement {
        string id PK
        string restaurantId FK
        string diningSessionId FK
        string currency FK
        string status "ENUM OPEN|PARTIAL|SETTLED|CANCELLED"
        string splitMode "ENUM FULL|BY_ITEM|EQUAL|CUSTOM"
        int subtotalCents
        int discountCents
        int tipAmountCents
        int taxAmountCents
        int totalCents
        int amountSettledCents
        int remainingCents
        string notes "nullable"
        timestamp createdAt
        timestamp updatedAt
        timestamp settledAt "nullable"
    }

    SettlementAllocation {
        string id PK
        string settlementId FK
        string orderItemId FK "nullable"
        string guestId FK "nullable"
        int amountCents
        timestamp createdAt
    }

    SettlementContribution {
        string id PK
        string settlementId FK
        string guestId FK "nullable"
        string registeredByUserId FK "nullable"
        string method "ENUM CASH|EXTERNAL|COURTESY|OTHER"
        int amountCents
        string note "nullable"
        timestamp createdAt
    }

    AppliedAdjustment {
        string id PK
        string restaurantId FK
        string orderItemId FK "nullable"
        string settlementId FK "nullable"
        string approvedByUserId FK "nullable"
        string type "ENUM DISCOUNT|COURTESY"
        string calculationMode "ENUM PERCENT|FIXED"
        int valueBps "nullable"
        int valueCents "nullable"
        int amountCents
        string reason
        string description "nullable"
        timestamp createdAt
    }

    AnalyticsJobRun {
        string id PK
        string restaurantId FK
        string status "ENUM QUEUED|RUNNING|COMPLETED|FAILED"
        string triggeredByUserId FK "nullable"
        timestamp startedAt
        timestamp finishedAt "nullable"
        string errorMessage "nullable"
        jsonb metadata "nullable"
    }

    AnalyticSalesDaily {
        string id PK
        string restaurantId FK
        date businessDate
        int orderCount
        int itemCount
        int grossConsumptionCents
        int discountCents
        int netConsumptionCents
        int avgServiceTimeSeconds
        timestamp computedAt
    }

    AnalyticItemVelocity {
        string id PK
        string restaurantId FK
        string menuItemId FK "nullable"
        date businessDate
        string itemNameSnapshot
        int quantitySold
        int grossConsumptionCents
        timestamp computedAt
    }

    AnalyticServiceTimes {
        string id PK
        string restaurantId FK
        string stationId FK "nullable"
        date businessDate
        int avgPrepSeconds
        int p50PrepSeconds
        int p90PrepSeconds
        int delayedItemsCount
        timestamp computedAt
    }

    AnalyticForecast {
        string id PK
        string restaurantId FK
        string menuItemId FK "nullable"
        date forecastDate
        int expectedQuantity
        int confidenceBps
        string method
        timestamp computedAt
    }

    Currency ||--o{ Chain : "usada en"
    Currency ||--o{ Restaurant : "usada en"
    Currency ||--o{ Settlement : "usada en"

    TaxGroup ||--o{ RestaurantCategory : "aplicado en"
    TaxGroup ||--o{ RestaurantMenuItem : "aplicado en"

    Permission ||--o{ RolePermission : "asignada en"
    Role ||--o{ RolePermission : "tiene"
    Role }o--o| Chain : "pertenece a"
    Role ||--o{ UserRole : "asignado en"

    AppUser ||--o{ UserRole : "tiene"
