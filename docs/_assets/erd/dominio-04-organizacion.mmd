erDiagram

    Chain {
        string id PK
        string createdBy FK
        string currency FK
        string name
        string logoUrl
        int defaultTaxBps
        string defaultTipsBps
        boolean isArchived
        timestamp createdAt
        timestamp updatedAt
    }

    Zone {
        string id PK
        string chainId FK
        string name
        boolean isArchived
        timestamp createdAt
        timestamp updatedAt
    }

    Restaurant {
        string id PK
        string chainId FK
        string zoneId FK
        string currency FK
        string name
        string logoUrl
        string welcomeMessage
        string address
        int taxBps
        string suggestedTipsBps
        boolean allowMobileOrdering
        boolean allowWaiterJoinTables
        boolean isArchived
        timestamp createdAt
        timestamp updatedAt
    }

    AuditLog {
        string id PK
        string actorUserId FK
        string chainId
        string restaurantId
        string action "CREATE|UPDATE|DELETE|LOGIN|OPEN_SESSION|CLOSE_SESSION|APPLY_ADJUSTMENT|REGISTER_CONTRIBUTION|RUN_ANALYTICS_JOB"
        string entityType
        string entityId
        jsonb before
        jsonb after
        jsonb metadata
        string ipAddress
        string userAgent
        timestamp createdAt
    }

    Chain ||--o{ Zone : "tiene"
    Chain ||--o{ Restaurant : "tiene"
    Zone ||--o{ Restaurant : "agrupa"
    AppUser ||--o{ Chain : "crea"
    AppUser ||--o{ AuditLog : "genera"
    Currency ||--o{ Chain : "usada"
    Currency ||--o{ Restaurant : "usada"
