\contentsline {figure}{\numberline {17}{\ignorespaces Modelo de Entidad-Relación Global (Simplificado) --- Bouquet OPS}}{110}{figure.caption.33}%
\contentsline {figure}{\numberline {18}{\ignorespaces Diagrama de secuencia del flujo de activaci\'on de mesa virtual por el Anfitr\'ion. Los pasos 11 son at\'omicos (transacci\'on PostgreSQL) para prevenir activaciones concurrentes (RO-07).}}{132}{figure.caption.35}%
\contentsline {figure}{\numberline {19}{\ignorespaces Arquitectura analítica de Bouquet OPS — Vista ejecutiva. El flujo va desde las tablas operacionales en Supabase hasta el dashboard de analítica en Next.js, pasando por el procesamiento en Spark sobre tablas analíticas (Gold).}}{137}{figure.caption.42}%
\contentsline {figure}{\numberline {20}{\ignorespaces Pipeline técnico de Spark — Vista detallada. Se muestran los cinco jobs secuenciales, el almacenamiento Parquet por capa y el flujo de escritura hacia las tablas analíticas en Supabase.}}{139}{figure.caption.43}%
\contentsline {figure}{\numberline {21}{\ignorespaces Linaje de \texttt {analytic\_sales\_daily}. El flujo consolida el núcleo operacional (órdenes e ítems) con el catálogo (restaurantes y cadenas) para generar una visión de ingresos por categoría y tiempo.}}{141}{figure.caption.44}%
\contentsline {figure}{\numberline {22}{\ignorespaces Linaje de \texttt {analytic\_item\_velocity}. Se enfoca en el comportamiento de cada producto, calculando ventanas de tiempo (7d/30d) y extrayendo la hora pico de demanda mediante funciones de agregación por hora.}}{142}{figure.caption.46}%
\contentsline {figure}{\numberline {23}{\ignorespaces Linaje de \texttt {analytic\_process\_mining}. Utiliza funciones de ventana para medir el ciclo de vida de cada ítem, desde su creación (\texttt {NEW}) hasta su entrega (\texttt {SERVED}).}}{143}{figure.caption.48}%
\contentsline {figure}{\numberline {24}{\ignorespaces Linaje de \texttt {analytic\_forecast}. Implementa una transformación estadística que cruza el promedio histórico por día de la semana con fechas futuras.}}{144}{figure.caption.50}%
