\contentsline {figure}{\numberline {9}{\ignorespaces CU-09: Auditoría de acciones y trazabilidad de cambios. Transparencia operativa.}}{97}{figure.caption.24}%
\contentsline {figure}{\numberline {10}{\ignorespaces CU-10: Configuración de modificadores y opciones de platillo. Flexibilidad en la personalización de órdenes.}}{98}{figure.caption.25}%
\contentsline {figure}{\numberline {11}{\ignorespaces CU-11: Aplicación de descuentos, cortesías y reembolsos. Gestión de excepciones financieras.}}{99}{figure.caption.26}%
\contentsline {figure}{\numberline {12}{\ignorespaces CU-12: Gestión de impuestos y parámetros fiscales. Garantiza el cumplimiento normativo en las transacciones.}}{100}{figure.caption.27}%
\contentsline {figure}{\numberline {13}{\ignorespaces CU-13: Ejecución de análisis y orquestación de pipeline Medallion. Separación de cargas OLTP y OLAP.}}{101}{figure.caption.28}%
\contentsline {figure}{\numberline {14}{\ignorespaces CU-14: Generación de pronósticos de demanda. Proporciona una visión predictiva para la toma de decisiones.}}{103}{figure.caption.29}%
